{
  "target_strict_score": 95,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [
    "node_modules",
    "packages/web/.next",
    "packages/web/node_modules",
    "packages/shared/node_modules",
    "gateway/_build",
    "gateway/deps",
    "prisma/migrations",
    "packages/web/coverage",
    ".claude",
    ".openhands",
    ".pi",
    ".desloppify"
  ],
  "ignore": [
    "security::packages/web/e2e/",
    "security::packages/web/app/api/v1/webhooks/route.ts::security::hardcoded_secret_name::packages/web/app/api/v1/webhooks/route.ts::66",
    "security::packages/web/components/modals/agent/simple-agent-forms.tsx::security::hardcoded_secret_name::packages/web/components/modals/agent/simple-agent-forms.tsx::172",
    "security::packages/web/components/modals/manage-agents-modal.tsx::security::hardcoded_secret_name::packages/web/components/modals/manage-agents-modal.tsx::38",
    "test_coverage::packages/web/app/",
    "test_coverage::packages/web/components/",
    "test_coverage::packages/web/lib/hooks/",
    "test_coverage::packages/cli/",
    "test_coverage::packages/shared/",
    "test_coverage::packages/web/contexts/",
    "test_coverage::packages/web/e2e/",
    "test_coverage::packages/web/scripts/",
    "test_coverage::packages/web/playwright.config.ts",
    "test_coverage::packages/web/middleware.ts"
  ],
  "ignore_metadata": {},
  "zone_overrides": {},
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "issue_noise_budget": 10,
  "issue_noise_global_budget": 0,
  "execution_log_max_entries": 10000,
  "needs_rescan": false,
  "languages": {},
  "commit_tracking_enabled": true,
  "commit_pr": 0,
  "commit_default_branch": "",
  "commit_message_template": "desloppify: {status} {count} issue(s) \u2014 {summary}",
  "trust_plugins": false
}
