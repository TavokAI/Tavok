# Tavok Configuration
#
# Quick start:   cp .env.example .env   (then replace all CHANGE-ME values)
# Auto-generate: ./scripts/setup.sh     (creates .env with random secrets)

# ============================================================
# DOMAIN & URLs
# ============================================================

# Your domain name (for Caddy HTTPS)
DOMAIN=localhost

# Full URL of the web app
NEXTAUTH_URL=http://localhost:5555

# WebSocket URL - clients connect here for real-time features
# Local: ws://localhost:4001/socket
# Production: wss://your-domain.com/socket
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:4001/socket

# Optional overrides when running Gateway/Streaming in Docker
# while running Web on host (pnpm dev).
GATEWAY_WEB_URL=http://web:5555
STREAMING_WEB_URL=http://web:5555

# ============================================================
# DATABASE
# ============================================================

POSTGRES_USER=tavok
POSTGRES_PASSWORD=tavok
POSTGRES_DB=tavok
DATABASE_URL=postgresql://tavok:tavok@db:5432/tavok

# ============================================================
# SECRETS - Generate with: openssl rand -base64 32
# ============================================================

NEXTAUTH_SECRET=CHANGE-ME
JWT_SECRET=CHANGE-ME
INTERNAL_API_SECRET=CHANGE-ME

# Phoenix secret - Generate with: openssl rand -base64 64
SECRET_KEY_BASE=CHANGE-ME

# AES-256 key - Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE-ME

# Redis password - Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE-ME

# ============================================================
# SERVICE PORTS
# ============================================================

# Host-side Postgres port mapping for Docker Compose.
# Defaults to 55432 to avoid collisions with local Postgres on 5432.
POSTGRES_HOST_PORT=55432
GATEWAY_PORT=4001
STREAMING_PORT=4002

# ============================================================
# ENVIRONMENT
# ============================================================

NODE_ENV=production
MIX_ENV=prod
