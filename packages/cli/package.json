{
  "name": "tavok",
  "version": "0.3.0",
  "description": "Tavok bootstrap CLI",
  "license": "MIT",
  "bin": {
    "tavok": "./bin/tavok.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "node -e \"try{require.resolve('vitest')}catch(e){console.error('ERROR: Run pnpm install from workspace root first');process.exit(1)}\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
