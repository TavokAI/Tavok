{
  "name": "tavok",
  "version": "0.3.0",
  "description": "Tavok bootstrap CLI",
  "license": "AGPL-3.0-or-later",
  "bin": {
    "tavok": "./bin/tavok.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "prepack": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "pretest": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
